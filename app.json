{
  "expo": {
    "name": "Metla JeBem",
    "slug": "expo-meta-wearables-dat-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "expo.modules.emwdat.example",
      "appleTeamId": "Q9DC849723",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app listens for voice commands to trigger one-shot scene understanding.",
        "NSSpeechRecognitionUsageDescription": "This app recognizes trigger phrases like \"What I see\" to capture and describe a frame.",
        "CFBundleDisplayName": "Metla JeBem",
        "UIBackgroundModes": ["audio"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "expo.modules.emwdat.example"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0"
          }
        }
      ],
      [
        "expo-meta-wearables-dat",
        {
          "urlScheme": "emwdat-example",
          "metaAppId": "1609318680350219",
          "clientToken": "AR|1609318680350219|8db12543c2dd86efe6e705e3bb93b9e4",
          "bluetoothUsageDescription": "This app uses Bluetooth to communicate with Meta Wearables glasses."
        }
      ],
      "./plugins/withRemoveMWDATEmbed"
    ],
    "extra": {
      "eas": {
        "projectId": "47bb4047-197c-4d8f-a0e1-011e8d882a0e"
      }
    }
  }
}
